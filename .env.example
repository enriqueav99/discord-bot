# Token del bot de Discord (obligatorio)
DISCORD_BOT_TOKEN=

# Prefijo de los comandos clásicos (opcional, default '<')
DISCORD_BOT_PREFIX=<

# IDs de los canales (obligatorios si no usas variables.json)
DISCORD_ID_CANAL_PRINCIPAL=
DISCORD_ID_CANAL_BOTS=

# Canal de logs de moderación (opcional — kick, ban, timeout, clear)
DISCORD_ID_CANAL_LOGS=

# Directorio donde se guardan whitelist.json y birthdays.json
# En producción apunta a un volumen persistente (ej. /app/data)
BOT_DATA_DIR=
