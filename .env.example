# Token del bot de Discord (obligatorio)
DISCORD_BOT_TOKEN=

# Prefijo de los comandos clásicos (opcional, default '<')
DISCORD_BOT_PREFIX=<

# IDs de los canales (obligatorios si no usas variables.json)
DISCORD_ID_CANAL_PRINCIPAL=
DISCORD_ID_CANAL_BOTS=

# Canal de logs de moderación (opcional — kick, ban, timeout, clear)
DISCORD_ID_CANAL_LOGS=

# Nombre del rol que necesitan los usuarios para usar el bot (opcional)
# Si no se define, cualquier miembro puede usar los comandos
DISCORD_REQUIRED_ROLE=

# Directorio donde se guardan birthdays.json
# En Docker el valor lo fija docker-compose.yml (bot-data:/app/data); solo
# es necesario definirlo aquí al correr el bot fuera de Docker.
BOT_DATA_DIR=
